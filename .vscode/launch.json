{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug WACAST Core",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/core",
            "cwd": "${workspaceFolder}/core",
            "envFile": "${workspaceFolder}/core/.env.example",
            "console": "integratedTerminal",
            "showLog": true
        },
        {
            "name": "Debug Current Go File",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${fileDirname}",
            "cwd": "${workspaceFolder}/core",
            "envFile": "${workspaceFolder}/core/.env",
            "console": "integratedTerminal",
            "showLog": true
        },
        {
            "name": "Attach to Go Process",
            "type": "go",
            "request": "attach",
            "mode": "local",
            "processId": "${command:pickProcess}",
            "cwd": "${workspaceFolder}/core",
            "showLog": true
        }
    ]
}
